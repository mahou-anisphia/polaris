# =============================================================================
# Polaris Sensor — environment configuration
#
# Copy this file to .env and fill in your values.
# The install scripts can import .env automatically if you provide the path.
# =============================================================================

# -----------------------------------------------------------------------------
# AQI Logger (src/local_logger/aqi_logger.py)
# -----------------------------------------------------------------------------
AQAIR_API_KEY=euphie-the-magical-girl
AQAIR_API_ENDPOINT=api.airvisual.com

# -----------------------------------------------------------------------------
# Station location
# Used by:
#   - GET /polaris-sensor/api/v2/location (Flask) — REQUIRED; returns HTTP 500 if unset
#   - src/kafka.py — optional; falls back to an ipinfo.io lookup if unset
# -----------------------------------------------------------------------------
STATION_LATITUDE=49.877968533823896
STATION_LONGITUDE=8.6792131710237

# -----------------------------------------------------------------------------
# Kafka Publisher (src/kafka.py)
# -----------------------------------------------------------------------------
KAFKA_BROKER=magicology-lab.com:9092